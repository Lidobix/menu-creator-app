{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./app/*"],
      // "@src/*": ["./src/*"],
      "@features/*": ["./src/features/*"],
      "@types": ["./src/types/types.ts"],
      "@assets/*": ["./assets/*"],
      "@config": ["./src/config/index.ts"],
      "@config/*": ["./src/config/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "scripts/create-feature.js"
  ]
}
